#!/bin/sh
# 哪吒[L1红线 + IDOR守卫 CI门 · 子项C]
# push 前自动跑 L1 合规红线断言 + IDOR 结构守卫, 任一红则拒绝 push。
# 应急绕过: git push --no-verify (须自负 L1/越权风险, 仅限明确无关改动)。
ROOT="$(git rev-parse --show-toplevel)" || exit 1
cd "$ROOT" || exit 1
if [ ! -f vendor/bin/phpunit ]; then
  echo "[pre-push] 跳过: 未找到 vendor/bin/phpunit"
  exit 0
fi
SUITES="tests/Feature/NezhaL1RedlineTest.php tests/Feature/NezhaIdorGuardTest.php tests/Feature/NezhaRiskChannelTest.php tests/Feature/NezhaCsGuidanceTest.php tests/Feature/NezhaTieredCouponParityTest.php tests/Unit/NezhaGetVarientDualFormatTest.php"
# 异常串外泄棘轮(2026-07-24 接入·文件存在才跑): 陈旧工作树尚未 checkout 此测试文件时自动跳过,
# 不误红账本/nzclaim/常规 push; 工作树够新(有此文件)即强制 —— 钉住 CLEANED_FILES 里 10 个控制器
# 不得回归把 $e->getMessage() 回客户端。误报(领域码/审过安全)改 CLEANED_FILES/AUDITED_SAFE 并在 CLAIMS 留痕。
if [ -f tests/Feature/NezhaApiExceptionLeakContractTest.php ]; then
  SUITES="$SUITES tests/Feature/NezhaApiExceptionLeakContractTest.php"
fi
echo "[pre-push] 跑 L1 红线 + IDOR 守卫 + 在场感知死指引墙 + 异常串外泄棘轮测试..."
php vendor/bin/phpunit $SUITES
if [ $? -ne 0 ]; then
  echo "[pre-push] 红线/IDOR守卫未通过, 拒绝 push。修复后再推(应急: git push --no-verify, 自负L1风险)。"
  exit 1
fi
echo "[pre-push] 红线通过, 允许 push。"
exit 0
