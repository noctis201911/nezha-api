#!/bin/sh
# 哪吒[L1红线 + IDOR守卫 CI门 · 子项C]
# push 前自动跑 L1 合规红线断言 + IDOR 结构守卫, 任一红则拒绝 push。
# 应急绕过: git push --no-verify (须自负 L1/越权风险, 仅限明确无关改动)。
ROOT="$(git rev-parse --show-toplevel)" || exit 1
cd "$ROOT" || exit 1
if [ ! -f vendor/bin/phpunit ]; then
  echo "[pre-push] 跳过: 未找到 vendor/bin/phpunit"
  exit 0
fi
echo "[pre-push] 跑 L1 红线 + IDOR 守卫 + 在场感知死指引墙测试..."
php vendor/bin/phpunit tests/Feature/NezhaL1RedlineTest.php tests/Feature/NezhaIdorGuardTest.php tests/Feature/NezhaRiskChannelTest.php tests/Feature/NezhaCsGuidanceTest.php tests/Feature/NezhaTieredCouponParityTest.php tests/Unit/NezhaGetVarientDualFormatTest.php
if [ $? -ne 0 ]; then
  echo "[pre-push] 红线/IDOR守卫未通过, 拒绝 push。修复后再推(应急: git push --no-verify, 自负L1风险)。"
  exit 1
fi
echo "[pre-push] 红线通过, 允许 push。"
exit 0
