#!/bin/sh
# 哪吒[L1红线 + IDOR守卫 CI门 · 子项C]
# push 前自动跑 L1 合规红线断言 + IDOR 结构守卫, 任一红则拒绝 push。
# 应急绕过: git push --no-verify (须自负 L1/越权风险, 仅限明确无关改动)。
ROOT="$(git rev-parse --show-toplevel)" || exit 1
cd "$ROOT" || exit 1
if [ ! -f vendor/bin/phpunit ]; then
  echo "[pre-push] 跳过: 未找到 vendor/bin/phpunit"
  exit 0
fi
# 固定墙(测试文件恒在): L1红线 / IDOR / 风控 / 死指引 / 满减配比
SUITES="tests/Feature/NezhaL1RedlineTest.php tests/Feature/NezhaIdorGuardTest.php tests/Feature/NezhaRiskChannelTest.php tests/Feature/NezhaCsGuidanceTest.php tests/Feature/NezhaTieredCouponParityTest.php"
# 以下为较晚加入的守卫测试: 用文件存在守卫, 老/陈旧工作树尚未 checkout 时自动跳过, 不误红别窗 push;
# 工作树够新(有该文件)即强制。
# 规格 get_varient money 双格式回归(0c705de8): 报价/下单/admin/vendor/POS 共用, 防双格式静默算错价。
if [ -f tests/Unit/NezhaGetVarientDualFormatTest.php ]; then
  SUITES="$SUITES tests/Unit/NezhaGetVarientDualFormatTest.php"
fi
# 异常串外泄棘轮(2026-07-24): 钉住 CLEANED_FILES 控制器不得回归把 getMessage() 回客户端。
if [ -f tests/Feature/NezhaApiExceptionLeakContractTest.php ]; then
  SUITES="$SUITES tests/Feature/NezhaApiExceptionLeakContractTest.php"
fi
echo "[pre-push] 跑 L1 红线 + IDOR 守卫 + 死指引墙 + 规格双格式 + 异常串外泄棘轮测试..."
php vendor/bin/phpunit $SUITES
if [ $? -ne 0 ]; then
  echo "[pre-push] 红线/IDOR守卫未通过, 拒绝 push。修复后再推(应急: git push --no-verify, 自负L1风险)。"
  exit 1
fi
echo "[pre-push] 红线通过, 允许 push。"
exit 0
