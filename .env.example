AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
SOFTWARE_VERSION = 9.0.1

# =====================================================================
# 哪吒项目补充键（线上 .env 实际在用、StackFood 原模板未列出的键）
# 值一律留空/占位；真实值见服务器 .env 或密码管理器，严禁写入本模板。
# =====================================================================

# 安装/许可（StackFood 安装流程使用，自托管按需填）
APP_INSTALL=
PURCHASE_CODE=
BUYER_USERNAME=
SOFTWARE_ID=
REACT_APP_KEY=

# 日志级别（与上面 LOG_LEVEL 并存，部分代码读 APP_LOG_LEVEL）
APP_LOG_LEVEL=

# 队列驱动（旧式键名，与 QUEUE_CONNECTION 并存）
QUEUE_DRIVER=sync

# 会话 cookie 名：固定为旧名，避免改 APP_NAME 后老会话集体失效
# （线上有具体值，部署时按现有 .env 填，新部署可留空让框架按默认生成）
SESSION_COOKIE=

# iPhone/iPad Home Screen Web Push (standard VAPID; independent of Firebase FCM)
# Keep one stable key pair. The private key belongs only in the server secret store.
WEB_PUSH_VAPID_SUBJECT=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
